{
  "expo": {
    "name": "SPARK PLATE",
    "slug": "sparkplate",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "sparkplate",
    "newArchEnabled": true,
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sparkplate.app",
      "infoPlist": {
        "UIFileSharingEnabled": true,
        "LSSupportsOpeningDocumentsInPlace": true,
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.sparkplate.app",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "讓 SPARK PLATE 存取您的照片以紀錄餐點",
          "cameraPermission": "讓 SPARK PLATE 使用相機拍攝餐點照片"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "讓 SPARK PLATE 儲存照片到您的相簿"
        }
      ],
      "./plugins/withRemoveRCTBridgeSourceURL.js"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fbecd76c-26e9-4d13-892e-7254d5a998b0"
      }
    },
    "owner": "mimichild"
  }
}
